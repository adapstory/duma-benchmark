# DUMA-Bench environment configuration
# Copy this file to .env and fill in your API keys.

# ── LLM Provider Keys ──────────────────────────────────────────────
# At least one provider key is required. DUMA-Bench uses LiteLLM,
# so any supported provider works (OpenAI, Anthropic, OpenRouter, etc.)

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# ── Custom / self-hosted provider ──────────────────────────────────
# If you use a custom OpenAI-compatible endpoint, set a key here
# and pass --agent-base-url <URL> --api-key-env CUSTOM_API_KEY at runtime.
# CUSTOM_API_KEY=

# ── Evaluator LLM ─────────────────────────────────────────────────
# The evaluator (NL assertions) can use a separate endpoint/key.
# If not set, it falls back to the default LiteLLM provider routing.
# EVALUATOR_API_BASE=https://api.openai.com/v1
# EVALUATOR_API_KEY=

# ── Optional: Caching ─────────────────────────────────────────────
# LLM_CACHE_ENABLED=True
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── Optional: Observability ───────────────────────────────────────
# USE_LANGFUSE=True
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
